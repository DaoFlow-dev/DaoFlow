# Auto-detect text files and normalize line endings
* text=auto

# Source code
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.css text eol=lf
*.html text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.svg text eol=lf
*.xml text eol=lf

# Config files
*.env text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf
.prettierrc text eol=lf
.prettierignore text eol=lf
Dockerfile text eol=lf
docker-compose.yml text eol=lf

# Shell scripts
*.sh text eol=lf

# Binary files
*.ico binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary

# Lock files — exact (don't diff)
bun.lock binary
package-lock.json binary

# Linguist overrides for GitHub
docs/** linguist-documentation
*.lock linguist-generated
