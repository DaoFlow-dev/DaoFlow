{
  "name": "daoflow",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"bun dev:server\" \"bun dev:client\"",
    "dev:server": "bun --watch src/server/index.ts",
    "dev:client": "vite",
    "build": "bun run build:client && bun run build:server",
    "build:client": "vite build",
    "build:server": "tsup src/server/index.ts --format esm --platform node --target node22 --out-dir dist/server --clean",
    "start": "NODE_ENV=production bun dist/server/index.js",
    "preview": "bun start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "bun run verify",
    "test:unit": "vitest run --coverage",
    "test:e2e": "playwright test",
    "verify": "bun run lint && bun run typecheck && bun run test:unit && bun run test:e2e",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@tanstack/react-query": "^5.90.2",
    "@trpc/client": "^11.7.1",
    "@trpc/react-query": "^11.7.1",
    "@trpc/server": "^11.7.1",
    "@types/pg": "8.18.0",
    "better-auth": "^1.5.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "drizzle-orm": "0.45.1",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "lucide-react": "^0.577.0",
    "morgan": "^1.10.1",
    "pg": "8.20.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "shadcn": "^4.0.6",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.1.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@playwright/test": "^1.55.0",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/morgan": "^1.9.10",
    "@types/node": "^24.5.2",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@types/supertest": "^6.0.3",
    "@vitejs/plugin-react": "^5.0.2",
    "@vitest/coverage-v8": "^4.0.7",
    "concurrently": "^9.2.1",
    "drizzle-kit": "0.31.9",
    "eslint": "^9.36.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.22",
    "globals": "^16.4.0",
    "jsdom": "^27.0.0",
    "supertest": "^7.1.4",
    "tailwindcss": "^4.2.1",
    "tsup": "^8.5.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.44.1",
    "vite": "^7.1.5",
    "vitest": "^4.0.7"
  }
}
