{
  "name": "daoflow",
  "version": "0.6.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.9",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "prepare": "if [ -f ./scripts/install-git-hooks.sh ]; then sh ./scripts/install-git-hooks.sh; fi",
    "dev": "concurrently -k \"bun --env-file .env --filter @daoflow/server dev\" \"bun --filter @daoflow/client dev\"",
    "dev:infra": "docker compose -f docker-compose.dev.yml up -d",
    "dev:temporal": "temporal server start-dev --port 7233 --ui-port 8233 --namespace daoflow",
    "dev:full": "concurrently -k -n infra,temporal,server,client \"bun run dev:infra\" \"bun run dev:temporal\" \"DAOFLOW_ENABLE_TEMPORAL=true bun --env-file .env --filter @daoflow/server dev\" \"bun --filter @daoflow/client dev\"",
    "build": "bun --filter @daoflow/shared build && bun --filter @daoflow/cli build && bun --filter @daoflow/server build && bun --filter @daoflow/client build",
    "build:client": "bun --filter @daoflow/client build",
    "build:server": "bun --filter @daoflow/server build",
    "contracts:generate": "bun ./scripts/generate-external-contracts.ts",
    "contracts:check": "bun ./scripts/generate-external-contracts.ts --check",
    "templates:check": "bun ./scripts/check-app-templates.ts",
    "templates:report": "bun ./scripts/check-app-templates.ts --report",
    "check:server-build-references": "bun --filter @daoflow/server build && bun --filter @daoflow/client typecheck",
    "start": "NODE_ENV=production bun packages/server/dist/index.js",
    "typecheck": "tsc -b packages/shared packages/server packages/client packages/cli",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "skills:check": "node ./scripts/check-skills.mjs",
    "test": "bun run verify",
    "test:unit": "bun --filter @daoflow/server test && bun --filter @daoflow/client test && bun --filter @daoflow/cli test",
    "test:e2e": "bun run test:e2e:main && bun run test:e2e:bootstrap",
    "test:e2e:main": "sh ./scripts/run-e2e-main.sh",
    "test:e2e:bootstrap": "sh ./scripts/run-e2e-bootstrap.sh",
    "test:e2e:worker": "./node_modules/.bin/playwright test --config playwright.worker.config.ts",
    "verify": "bun run format:check && bun run lint && bun run typecheck && bun run contracts:check && bun run test:unit",
    "db:generate": "drizzle-kit generate",
    "db:generate:fresh": "bun packages/server/src/db/regenerate-migrations.ts",
    "db:migrate": "bun packages/server/src/db/migration.ts",
    "db:reset": "bun packages/server/src/db/reset.ts",
    "db:rebuild": "bun run db:reset && bun run db:migrate && bun run db:seed",
    "db:push": "drizzle-kit push",
    "db:push:ci": "drizzle-kit push --force",
    "db:seed": "bun packages/server/src/db/services/run-seed.ts",
    "db:seed:e2e-auth": "bun packages/server/src/db/services/seed-e2e-auth-users.ts",
    "db:studio": "drizzle-kit studio",
    "cli": "bun packages/cli/src/index.ts",
    "hooks:install": "sh ./scripts/install-git-hooks.sh"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@playwright/test": "^1.55.0",
    "@types/bun": "1.3.10",
    "concurrently": "^9.2.1",
    "drizzle-kit": "0.31.9",
    "eslint": "^9.36.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.22",
    "globals": "^16.4.0",
    "prettier": "^3.6.2",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.44.1"
  }
}
