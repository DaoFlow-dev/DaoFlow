{
  "name": "daoflow",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -k \"bun --filter @daoflow/server dev\" \"bun --filter @daoflow/client dev\"",
    "build": "bun --filter '*' build",
    "build:client": "bun --filter @daoflow/client build",
    "build:server": "bun --filter @daoflow/server build",
    "start": "NODE_ENV=production bun packages/server/dist/index.js",
    "typecheck": "tsc -b packages/shared packages/server packages/client packages/cli",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "bun run verify",
    "test:unit": "bun --filter @daoflow/server test",
    "test:e2e": "playwright test",
    "verify": "bun run format:check && bun run lint && bun run typecheck && bun run test:unit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun packages/server/src/db/migration.ts",
    "db:push": "drizzle-kit push",
    "db:push:ci": "drizzle-kit push --force",
    "db:seed": "bun packages/server/src/db/services/run-seed.ts",
    "db:studio": "drizzle-kit studio",
    "cli": "bun packages/cli/src/index.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@playwright/test": "^1.55.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.36.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.22",
    "globals": "^16.4.0",
    "prettier": "^3.6.2",
    "drizzle-kit": "0.31.9",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.44.1"
  },
  "packageManager": "pnpm@10.28.0+sha512.05df71d1421f21399e053fde567cea34d446fa02c76571441bfc1c7956e98e363088982d940465fd34480d4d90a0668bc12362f8aa88000a64e83d0b0e47be48"
}
