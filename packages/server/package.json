{
  "name": "@daoflow/server",
  "version": "0.3.5",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./src/index.ts"
    },
    "./router": {
      "types": "./dist/src/router.d.ts",
      "default": "./src/router.ts"
    }
  },
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "tsup src/index.ts --format esm --platform node --target node22 --out-dir dist --clean && tsc -p tsconfig.json --emitDeclarationOnly && mkdir -p dist/workflows && cp -R src/worker/temporal/workflows/. dist/workflows",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --coverage"
  },
  "dependencies": {
    "@1password/sdk": "0.4.0",
    "@daoflow/shared": "workspace:*",
    "@hono/trpc-server": "0.4.2",
    "@temporalio/activity": "1.15.0",
    "@temporalio/client": "1.15.0",
    "@temporalio/common": "1.15.0",
    "@temporalio/worker": "1.15.0",
    "@temporalio/workflow": "1.15.0",
    "@trpc/server": "^11.7.1",
    "@types/pg": "8.18.0",
    "better-auth": "^1.5.5",
    "drizzle-orm": "0.45.1",
    "hono": "4.12.7",
    "nodemailer": "8.0.2",
    "pg": "8.20.0",
    "web-push": "3.6.7",
    "yaml": "2.8.2",
    "zod": "^4.1.8"
  },
  "devDependencies": {
    "@types/bun": "1.3.10",
    "@types/node": "^24.5.2",
    "@types/nodemailer": "7.0.11",
    "@types/web-push": "3.6.4",
    "@vitest/coverage-v8": "^4.0.7",
    "drizzle-kit": "0.31.9",
    "jsdom": "^27.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.2",
    "vitest": "^4.0.7"
  }
}
