{
  "name": "@daoflow/server",
  "version": "0.11.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./router": {
      "types": "./src/router.ts",
      "default": "./src/router.ts"
    },
    "./router-types": {
      "types": "./src/router-types.ts",
      "default": "./src/router-types.ts"
    }
  },
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "tsup src/index.ts --format esm --platform node --target node22 --out-dir dist --clean && tsc -p tsconfig.json --emitDeclarationOnly && mkdir -p dist/workflows && cp -R src/worker/temporal/workflows/. dist/workflows",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --coverage",
    "openapi": "bun src/openapi-schema.ts"
  },
  "dependencies": {
    "@1password/sdk": "0.4.0",
    "@aws-sdk/client-s3": "3.1090.0",
    "@daoflow/shared": "workspace:*",
    "@hono/trpc-server": "0.4.2",
    "@sandbank.dev/boxlite": "0.7.1",
    "@sandbank.dev/core": "0.3.6",
    "@temporalio/activity": "1.20.3",
    "@temporalio/client": "1.20.3",
    "@temporalio/common": "1.20.3",
    "@temporalio/worker": "1.20.3",
    "@temporalio/workflow": "1.20.3",
    "@trpc/server": "11.18.0",
    "@types/pg": "8.20.0",
    "better-auth": "1.6.23",
    "drizzle-orm": "0.45.2",
    "hono": "4.12.31",
    "nodemailer": "9.0.3",
    "pg": "8.22.0",
    "web-push": "3.6.7",
    "yaml": "2.9.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/bun": "1.3.14",
    "@types/node": "26.1.1",
    "@types/nodemailer": "8.0.1",
    "@types/web-push": "3.6.4",
    "@vitest/coverage-v8": "4.1.10",
    "drizzle-kit": "0.31.10",
    "jsdom": "29.1.1",
    "tsup": "8.5.1",
    "typescript": "7.0.2",
    "vitest": "4.1.10"
  }
}
