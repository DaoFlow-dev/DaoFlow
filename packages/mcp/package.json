{
  "name": "@daoflow/mcp",
  "version": "0.10.0",
  "private": true,
  "type": "module",
  "description": "Model Context Protocol server exposing DaoFlow's agent-safe read, planning, and command surface over stdio.",
  "bin": {
    "daoflow-mcp": "./src/index.ts"
  },
  "scripts": {
    "dev": "bun src/index.ts",
    "build": "bun build src/index.ts --compile --outfile dist/daoflow-mcp",
    "build:linux": "bun build src/index.ts --compile --target=bun-linux-x64-baseline --outfile dist/daoflow-mcp-linux-x64",
    "build:linux-arm64": "bun build src/index.ts --compile --target=bun-linux-arm64 --outfile dist/daoflow-mcp-linux-arm64",
    "build:mac": "bun build src/index.ts --compile --target=bun-darwin-arm64 --outfile dist/daoflow-mcp-darwin-arm64",
    "build:mac-x64": "bun build src/index.ts --compile --target=bun-darwin-x64 --outfile dist/daoflow-mcp-darwin-x64",
    "build:all": "bun run build:linux && bun run build:linux-arm64 && bun run build:mac && bun run build:mac-x64",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "@trpc/client": "11.18.0",
    "@trpc/server": "11.18.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/bun": "1.3.14",
    "@types/node": "26.1.1",
    "typescript": "7.0.2"
  }
}
