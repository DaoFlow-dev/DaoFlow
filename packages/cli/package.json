{
  "name": "@daoflow/cli",
  "version": "0.11.0",
  "private": true,
  "type": "module",
  "bin": {
    "daoflow": "./src/index.ts"
  },
  "scripts": {
    "dev": "bun src/index.ts",
    "build": "bun build src/index.ts --compile --outfile dist/daoflow",
    "build:linux": "bun build src/index.ts --compile --target=bun-linux-x64-baseline --outfile dist/daoflow-linux-x64",
    "build:linux-arm64": "bun build src/index.ts --compile --target=bun-linux-arm64 --outfile dist/daoflow-linux-arm64",
    "build:mac": "bun build src/index.ts --compile --target=bun-darwin-arm64 --outfile dist/daoflow-darwin-arm64",
    "build:mac-x64": "bun build src/index.ts --compile --target=bun-darwin-x64 --outfile dist/daoflow-darwin-x64",
    "build:all": "bun run build:linux && bun run build:linux-arm64 && bun run build:mac && bun run build:mac-x64",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@balena/dockerignore": "1.0.2",
    "@daoflow/shared": "workspace:*",
    "@trpc/client": "11.18.0",
    "@trpc/server": "11.18.0",
    "chalk": "5.6.2",
    "commander": "15.0.0",
    "dockerode": "5.0.1",
    "jsonc-parser": "3.3.1",
    "ora": "9.4.1",
    "smol-toml": "1.7.0",
    "yaml": "2.9.0"
  },
  "devDependencies": {
    "@daoflow/server": "workspace:*",
    "@types/bun": "1.3.14",
    "@types/dockerode": "4.0.1",
    "@types/node": "26.1.1",
    "typescript": "7.0.2"
  }
}
