#!/usr/bin/env sh
set -eu

if [ "${DAOFLOW_SKIP_PRECOMMIT:-}" = "1" ]; then
  echo "[pre-commit] skipped because DAOFLOW_SKIP_PRECOMMIT=1"
  exit 0
fi

if ! command -v bun >/dev/null 2>&1; then
  echo "[pre-commit] bun is required" >&2
  exit 1
fi

# Collect staged files (excludes deleted files)
STAGED=$(git diff --cached --name-only --diff-filter=d)

if [ -z "$STAGED" ]; then
  echo "[pre-commit] no staged files, skipping"
  exit 0
fi

staged_prettier_files() {
  git diff --cached --name-only --diff-filter=d "$@" -- \
    '*.ts' '*.tsx' '*.js' '*.jsx' '*.mjs' '*.cjs' '*.json' '*.css' '*.md' '*.yaml' '*.yml' '*.html'
}

if staged_prettier_files | grep -q .; then
  echo "[pre-commit] formatting staged files"
  staged_prettier_files -z | xargs -0 bun x prettier --write --
  staged_prettier_files -z | xargs -0 git add --
fi

echo "[pre-commit] bun run lint"
bun run lint

echo "[pre-commit] bun run typecheck"
bun run typecheck

echo "[pre-commit] bun run contracts:check"
bun run contracts:check
