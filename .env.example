# DaoFlow Environment Variables
# Copy to .env and fill in your values

# Database (Postgres 17 + pgvector)
DATABASE_URL=postgresql://daoflow:daoflow_dev@localhost:5432/daoflow

# Redis (job queue + SSE streaming)
REDIS_URL=redis://localhost:6379

# Better Auth
BETTER_AUTH_SECRET=change-me-to-a-random-string-at-least-32-chars
BETTER_AUTH_URL=http://localhost:3000

# Encryption key for environment variable secrets (32+ chars)
ENCRYPTION_KEY=change-me-to-a-random-encryption-key-32chars

# Server
PORT=3000
NODE_ENV=development
