# DaoFlow Production Environment Variables
# Auto-generated by `daoflow install` or copy this file to .env and fill in values.
#
# Generate secure values with:
#   BETTER_AUTH_SECRET: openssl rand -hex 32
#   ENCRYPTION_KEY:     openssl rand -hex 32

# ── Required Secrets (auto-generated by `daoflow install`) ────
BETTER_AUTH_SECRET=
ENCRYPTION_KEY=
# Optional destination-only key rotation settings. The current destination key
# defaults to ENCRYPTION_KEY; set the previous key only for the rotation window.
# DAOFLOW_BACKUP_DESTINATION_ENCRYPTION_KEY=
# DAOFLOW_PREVIOUS_BACKUP_DESTINATION_ENCRYPTION_KEY=
POSTGRES_PASSWORD=
# Lean can omit this; it is required only when DAOFLOW_WORKFLOW_PROFILE=temporal.
# TEMPORAL_POSTGRES_PASSWORD=

# ── Public URL ────────────────────────────────────────────────
BETTER_AUTH_URL=http://localhost:3000

# ── Version ───────────────────────────────────────────────────
DAOFLOW_VERSION=0.9.1

# ── Installation Profile ─────────────────────────────────────
# Lean is the default: only daoflow, postgres, and redis start.
DAOFLOW_WORKFLOW_PROFILE=lean
# Lean has no active Compose profiles. Set COMPOSE_PROFILES=temporal with the other two values
# when selecting the Temporal profile.
COMPOSE_PROFILES=
DAOFLOW_ENABLE_TEMPORAL=false

# ── Ports (optional overrides) ────────────────────────────────
# DAOFLOW_BIND=127.0.0.1
# DAOFLOW_PORT=3000
# TEMPORAL_UI_PORT=8233 # only used with: docker compose --profile temporal-ui up -d

# ── Deployment Worker ─────────────────────────────────────────
# DEPLOY_TIMEOUT_MS=600000

# ── Temporal (used only with the temporal workflow profile) ───
# TEMPORAL_NAMESPACE=daoflow
# TEMPORAL_TASK_QUEUE=daoflow-deployments
# TEMPORAL_ADDRESS=temporal:7233

# ── CORS ──────────────────────────────────────────────────────
# CORS_ORIGIN=https://your-domain.com
