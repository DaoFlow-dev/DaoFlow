# DaoFlow Production Environment Variables
# Auto-generated by `daoflow install` or copy this file to .env and fill in values.
#
# Generate secure values with: openssl rand -hex 32

# ── Required Secrets (auto-generated by `daoflow install`) ────
BETTER_AUTH_SECRET=
ENCRYPTION_KEY=
POSTGRES_PASSWORD=
TEMPORAL_POSTGRES_PASSWORD=

# ── Public URL ────────────────────────────────────────────────
BETTER_AUTH_URL=http://localhost:3000

# ── Version ───────────────────────────────────────────────────
DAOFLOW_VERSION=latest

# ── Ports (optional overrides) ────────────────────────────────
# DAOFLOW_PORT=3000
# TEMPORAL_UI_PORT=8233

# ── Deployment Worker ─────────────────────────────────────────
# DEPLOY_TIMEOUT_MS=600000

# ── Temporal (defaults are fine for most setups) ──────────────
# TEMPORAL_NAMESPACE=daoflow
# TEMPORAL_TASK_QUEUE=daoflow-deployments

# ── CORS ──────────────────────────────────────────────────────
# CORS_ORIGIN=https://your-domain.com
