# DaoFlow Production Environment Variables
# Copy to .env and update values before deploying.

# ── Required Secrets ──────────────────────────────────────────
# Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=change-me-to-random-32-char-hex
ENCRYPTION_KEY=change-me-to-random-32-char-hex

# ── Database ──────────────────────────────────────────────────
POSTGRES_PASSWORD=change-me-strong-password

# ── Public URL ────────────────────────────────────────────────
BETTER_AUTH_URL=https://your-domain.com

# ── Optional ──────────────────────────────────────────────────
# DEPLOY_TIMEOUT_MS=600000
# CORS_ORIGIN=https://your-domain.com
# TEMPORAL_ADDRESS=temporal:7233
# TEMPORAL_NAMESPACE=daoflow
# TEMPORAL_TASK_QUEUE=daoflow-deployments
